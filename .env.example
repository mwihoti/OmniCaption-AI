# OmniCaption AI — API keys
# Copy to .env and fill in. You don't need all of them; each capability has
# fallbacks. Minimum recommended: GROQ_API_KEY + NVIDIA_API_KEY.

# Groq — PRIMARY for chat (story + captions) and Whisper transcription
# https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# NVIDIA NIM — PRIMARY for vision / scene understanding
# https://build.nvidia.com
NVIDIA_API_KEY=nvapi_xxxxxxxxxxxxxxxx

# Google Gemini — vision fallback (optional)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxx

# Fireworks AI — chat + transcription fallback (optional)
# https://fireworks.ai
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxx

# Hugging Face — emotion classifier + vision fallback (optional)
# https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
